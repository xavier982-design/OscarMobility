FROM python:3.12-slim

WORKDIR /app

# Install dependencies from dedicated test requirements.
COPY requirements.txt requirements.test.txt ./
RUN pip install --no-cache-dir --root-user-action=ignore -r requirements.test.txt

# Copy source and tests.
COPY . .

# Tests are fully mocked for external services, so no extra containers are required.
CMD ["pytest", "tests/", "-v", "--tb=short"]